<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirect favicon.ico to favicon.png
  RewriteRule ^favicon\.ico$ /favicon.png [L]
  
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
