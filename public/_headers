# Force no caching on HTML files
/
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/index.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Long-term cache for versioned assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable
